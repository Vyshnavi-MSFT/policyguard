<Project Sdk="Microsoft.NET.Sdk">

  <!--
    PolicyGuard.Api project file.
    NOTE (Person F): created as a class library so Person F's code (PolicyStore,
    LlmReasoner) compiles and is unit-testable before Person E finishes Program.cs.
    Person E can change the SDK to "Microsoft.NET.Sdk.Web" and add an entry point
    once the API host is ready.
  -->

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>PolicyGuard.Api</RootNamespace>
    <AssemblyName>PolicyGuard.Api</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Azure.AI.OpenAI" Version="2.1.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="8.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" Version="8.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="8.0.0" />
    <PackageReference Include="DotNetEnv" Version="3.1.1" />
  </ItemGroup>

</Project>
